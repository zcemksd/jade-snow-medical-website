---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import DualMarqueeGallery from "../components/DualMarqueeGallery.jsx";
import ScrollReveal from "../components/ScrollReveal.astro";
import "../styles/global.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/jadesnow-logo.png" />
    <meta name="viewport" content="width=device-width" />
    <title>Clinical Use - Jade Snow Medical</title>
  </head>
  <body class="bg-white text-gray-900">
    <Navbar />
    
    <main class="max-w-7xl mx-auto px-6 py-16">
      <section class="text-center mb-16">
        <ScrollReveal>
          <h1 class="text-4xl font-semibold text-gray-900 mb-4">
            Clinical Education in Action
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Our models support neurosurgical training programs at leading institutions worldwide. 
            From single-day workshops to comprehensive fellowship curricula, we enable hands-on 
            learning with realistic, patient-specific anatomy.
          </p>
        </ScrollReveal>
      </section>

      <!-- Featured Partner -->
      <section class="mb-16 bg-jade-50 rounded-lg p-8">
        <ScrollReveal>
          <div class="grid md:grid-cols-2 gap-8 items-center">
            <div>
              <h2 class="text-2xl font-semibold mb-4">
                National Hospital for Neurology and Neurosurgery
              </h2>
              <p class="text-gray-700 mb-4">
                Queen Square, London — University College London Hospitals NHS Foundation Trust
              </p>
              <p class="text-gray-600 mb-6">
                Our flagship partnership. Since 2023, we have delivered over 300 patient-specific 
                models supporting 10+ neurosurgical training courses, reaching 100+ surgeons in 
                training across multiple subspecialties.
              </p>
              <div class="grid grid-cols-2 gap-4 text-base">
                <div>
                  <div class="text-2xl font-bold text-jade-500 mb-1">92%</div>
                  <div class="text-gray-600">Satisfaction Score</div>
                </div>
                <div>
                  <div class="text-2xl font-bold text-jade-500 mb-1">9+/10</div>
                  <div class="text-gray-600">Usability Rating</div>
                </div>
              </div>
            </div>
            <div class="h-64 overflow-hidden rounded-lg">
              <img 
                src="/images/nhnn_team.JPG" 
                alt="National Hospital for Neurology and Neurosurgery training course" 
                class="w-full h-full object-cover object-center"
                style="object-position: 50% 40%;"
              />
            </div>
          </ScrollReveal>
        </div>
      </section>

      <!-- Impact Metrics -->
      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-4xl font-semibold mb-12 text-center">Training Impact</h2>
        </ScrollReveal>
        <div class="grid md:grid-cols-2 gap-12">
          
          <ScrollReveal delay={200}>
            <div class="bg-gradient-to-br from-jade-50 to-white rounded-lg p-10 border border-jade-100 h-full">
              <div class="flex items-center gap-4 mb-8">
                <div class="w-14 h-14 bg-jade-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                  </svg>
                </div>
                <h3 class="text-2xl font-semibold">Course Types Supported</h3>
              </div>
              <ul class="space-y-4">
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Skull Base Approaches & Techniques</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Emergency Neurosurgical Procedures (EVD, Burr Holes)</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Craniotomy & Craniectomy Training</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Foramen Magnum Decompression</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Temporal Bone & Lateral Skull Base</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Pituitary & Functional Neurosurgery</span>
                </li>
              </ul>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={400}>
            <div class="bg-gradient-to-br from-gray-50 to-white rounded-lg p-10 border border-gray-200 h-full">
              <div class="flex items-center gap-4 mb-8">
                <div class="w-14 h-14 bg-jade-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </div>
                <h3 class="text-2xl font-semibold">Who We've Worked With</h3>
              </div>
              <ul class="space-y-4">
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Neurosurgical residency programmes</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Fellowship training courses</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Consultant-level skills development</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Academic surgical research projects</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Medical device validation studies</span>
                </li>
              </ul>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <!-- Testimonials / Feedback -->
      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-8 text-center">What Surgeons Say</h2>
        </ScrollReveal>
        
        <div class="grid md:grid-cols-2 gap-8">
          
          <ScrollReveal delay={200}>
            <div class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-4xl text-jade-500 mb-3">"</div>
              <p class="text-gray-700 italic mb-4 flex-1">
                Using 3D printed brain models were very helpful to understand and get better in the skills. 
                Great work! Accurate skull modelling, would be happy to use in the future.
              </p>
              <p class="text-base text-gray-500">— Neurosurgical Trainee, NHNN Drilling Course</p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={400}>
            <div class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-4xl text-jade-500 mb-3">"</div>
              <p class="text-gray-700 italic mb-4 flex-1">
                Skull itself was very realistic in shape. Drilling texture and resistance felt quite true to real life. 
                Useful for finding landmarks and getting the sensation of drilling.
              </p>
              <p class="text-base text-gray-500">— Doctor, UCLH Training Programme</p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={600}>
            <div class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-4xl text-jade-500 mb-3">"</div>
              <p class="text-gray-700 italic mb-4 flex-1">
                Overall they were of a very high quality. The simulation was a very valuable training ground, 
                allowing to develop and refine skills in a controlled environment.
              </p>
              <p class="text-base text-gray-500">— FY1 Doctor, Surgical Skills Course</p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={800}>
            <div class="bg-white border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-4xl text-jade-500 mb-3">"</div>
              <p class="text-gray-700 italic mb-4 flex-1">
                Fine details such as sutures and foramina were accurately represented. 
                The setup was overall user-friendly and easy to set up with clear instructions.
              </p>
              <p class="text-base text-gray-500">— Surgical Trainee, NHNN</p>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <!-- Selected Course Highlights -->
      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-8 text-center">Selected Course Highlights</h2>
        </ScrollReveal>
        <div class="grid md:grid-cols-3 gap-6">
          
          <ScrollReveal delay={200}>
            <div class="border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-jade-500 font-bold mb-2">2023-2025</div>
              <h3 class="font-semibold mb-2">UCLH Neurosurgery Program</h3>
              <p class="text-base text-gray-600 flex-1">
                Ongoing partnership supporting multiple training courses annually including skull base, EVD, and craniotomy training.
              </p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={400}>
            <div class="border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-jade-500 font-bold mb-2">2024</div>
              <h3 class="font-semibold mb-2">Temporal Bone Course</h3>
              <p class="text-base text-gray-600 flex-1">
                60 high-fidelity temporal bone models delivered for lateral skull base approach training.
              </p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={600}>
            <div class="border border-gray-200 rounded-lg p-6 flex flex-col h-full">
              <div class="text-jade-500 font-bold mb-2">2025</div>
              <h3 class="font-semibold mb-2">Neural Canal Research</h3>
              <p class="text-base text-gray-600 flex-1">
                110 specialized models produced for academic research collaboration on surgical technique development.
              </p>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <!-- Training Photos Gallery -->
      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-8 text-center">Training in Action</h2>
        </ScrollReveal>
        
        <DualMarqueeGallery 
          client:load
          topImages={[
            '/images/drilling_2.jpg',
            '/images/drilling.jpg',
            '/images/fmd.jpg',
            '/images/drilling_training.jpg'
          ]}
          bottomImages={[
            '/images/dura.jpg',
            '/images/fmd_train.JPG',
            '/images/skull_base.jpg',
            '/images/nhnn_team.JPG'
          ]}
        />
      </section>

      <section class="bg-gray-50 rounded-lg p-8 text-center">
        <h2 class="text-2xl font-semibold mb-4">Bring Jade Snow Medical to Your Institution</h2>
        <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
          We partner with hospitals and training programs worldwide. Contact us to discuss 
          how our models can enhance your surgical education curriculum.
        </p>
        <a href="/contact" class="inline-block bg-jade-500 text-white px-8 py-3 rounded-lg hover:bg-jade-600 transition">
          Get in Touch
        </a>
      </section>
    </main>
    <Footer />
  </body>
</html>