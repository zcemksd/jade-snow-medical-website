---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import "../styles/global.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/jadesnow-logo.png" />
    <meta name="viewport" content="width=device-width" />
    <title>Products - Jade Snow Medical</title>
  </head>
  <body class="bg-white text-gray-900">
    <Navbar />
    
    <main class="max-w-7xl mx-auto px-6 py-16">
      <section class="text-center mb-16">
        <ScrollReveal>
          <h1 class="text-4xl font-semibold text-gray-900 mb-4">
            NeuroPrint: Neurosurgical Training Models
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Patient-specific 3D printed anatomical models for neurosurgical training. 
            Realistic, repeatable, ethical alternative to cadavers.
          </p>
        </ScrollReveal>
      </section>

      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-8 text-center">Current Models</h2>
        </ScrollReveal>

        <div class="grid md:grid-cols-3 gap-8">
          
          <!-- Foramen Magnum Model -->
          <ScrollReveal delay={200}>
            <div class="border border-gray-200 rounded-lg overflow-hidden h-full flex flex-col">
              <div class="h-64 overflow-hidden flex-shrink-0">
                <img 
                  src="/images/fmd.jpg" 
                  alt="Foramen Magnum Decompression Model" 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <h3 class="text-xl font-semibold mb-3">Foramen Magnum Decompression Model</h3>
                <p class="text-gray-600 text-base mb-4 flex-1 text-justify">
                  Anatomically accurate posterior fossa model for practicing foramen magnum 
                  decompression procedures. Includes occipital bone, C1 vertebra, and relevant 
                  anatomical landmarks.
                </p>
                <p class="text-sm text-gray-500 font-semibold text-justify">
                  Use: Chiari malformation surgery training, suboccipital craniectomy practice
                </p>
              </div>
            </div>
          </ScrollReveal>

          <!-- EVD Model -->
          <ScrollReveal delay={400}>
            <div class="border border-gray-200 rounded-lg overflow-hidden h-full flex flex-col">
              <div class="h-64 overflow-hidden flex-shrink-0">
                <img 
                  src="/images/evd.jpg" 
                  alt="External Ventricular Drain Model" 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <h3 class="text-xl font-semibold mb-3">External Ventricular Drain (EVD) Model</h3>
                <p class="text-gray-600 text-base mb-4 flex-1 text-justify">
                  Realistic model for practicing EVD insertion technique. Features accurate 
                  ventricular anatomy and surface landmarks for safe catheter placement.
                </p>
                <p class="text-sm text-gray-500 font-semibold text-justify">
                  Use: Emergency neurosurgical procedure training, resident skill development
                </p>
              </div>
            </div>
          </ScrollReveal>

          <!-- Cranial Drilling Model -->
          <ScrollReveal delay={600}>
            <div class="border border-gray-200 rounded-lg overflow-hidden h-full flex flex-col">
              <div class="h-64 overflow-hidden flex-shrink-0">
                <img 
                  src="/images/cranial_drilling.jpeg" 
                  alt="Cranial Drilling Practice Model" 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6 flex-1 flex flex-col">
                <h3 class="text-xl font-semibold mb-3">Cranial Drilling Practice Model</h3>
                <p class="text-gray-600 text-base mb-4 flex-1 text-justify">
                  Half skull model with brain and dura mater. Designed for practicing 
                  craniotomy techniques, burr hole placement, and safe drilling without 
                  dural penetration.
                </p>
                <p class="text-sm text-gray-500 font-semibold text-justify">
                  Use: Craniotomy training, surgical skills lab, instrument familiarization
                </p>
              </div>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-4xl font-semibold mb-12 text-center">Why NeuroPrint Models?</h2>
        </ScrollReveal>
        
        <div class="grid md:grid-cols-2 gap-12 items-stretch">
          
          <!-- For Training Programmes -->
          <ScrollReveal delay={200}>
            <div class="bg-gradient-to-br from-jade-50 to-white rounded-lg p-10 border border-jade-100 h-full">
              <div class="flex items-center gap-4 mb-8">
                <div class="w-14 h-14 bg-jade-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                  </svg>
                </div>
                <h3 class="text-2xl font-semibold">For Training Programmes</h3>
              </div>
              
              <ul class="space-y-4">
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Repeatable practice without cadaver dependency</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Multiple residents can train simultaneously</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Consistent anatomical quality</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">No ethical or storage concerns</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Lower cost per training session</span>
                </li>
              </ul>
            </div>
          </ScrollReveal>

          <!-- For Surgeons -->
          <ScrollReveal delay={400}>
            <div class="bg-gradient-to-br from-gray-50 to-white rounded-lg p-10 border border-gray-200 h-full">
              <div class="flex items-center gap-4 mb-8">
                <div class="w-14 h-14 bg-jade-500 rounded-lg flex items-center justify-center flex-shrink-0">
                  <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <h3 class="text-2xl font-semibold">For Surgeons</h3>
              </div>
              
              <ul class="space-y-4">
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Build muscle memory for critical procedures</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Practice rare or high-risk cases safely</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Train with actual surgical instruments</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Realistic tactile feedback</span>
                </li>
                <li class="flex items-start gap-4">
                  <span class="text-jade-500 font-bold text-xl flex-shrink-0">•</span>
                  <span class="text-gray-700 text-lg leading-relaxed">Patient-specific anatomy when needed</span>
                </li>
              </ul>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <section class="bg-gray-50 rounded-lg p-8 text-center">
        <h2 class="text-2xl font-semibold mb-4">Partner With Us</h2>
        <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
          We work with hospitals, surgical training programmes, and medical schools worldwide. 
          Contact us to discuss bulk orders, custom models, or collaborative development.
        </p>
        <a href="/contact" class="inline-block bg-jade-500 text-white px-8 py-3 rounded-lg hover:bg-jade-600 transition">
          Get in Touch
        </a>
      </section>
    </main>
    <Footer />
  </body>
</html>
