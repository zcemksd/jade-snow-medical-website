---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import NetworkMap from "../components/NetworkMap.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import "../styles/global.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Decentralized Network - Jade Snow Medical</title>
  </head>
  <body class="bg-white text-gray-900">
    <Navbar />
    
    <main class="max-w-7xl mx-auto px-6 py-16">
      <section class="text-center mb-16">
        <ScrollReveal>
          <h1 class="text-4xl font-semibold text-gray-900 mb-4">
            Decentralized Production Network
          </h1>
          <p class="text-xl text-gray-600 max-w-3xl mx-auto">
            Centralized expertise in medical imaging and model design. 
            Distributed manufacturing for speed, sustainability, and global reach.
          </p>
        </ScrollReveal>
      </section>

      <section class="mb-16">
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-8 text-center">How It Works</h2>
        </ScrollReveal>

        <div class="grid md:grid-cols-3 gap-8">

          <ScrollReveal delay={200}>
            <div class="text-center">
              <div class="bg-jade-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-jade-500">1</span>
              </div>
              <h3 class="font-semibold mb-2">Centralized Processing</h3>
              <p class="text-gray-600 text-base">
                Medical scans processed by our expert team. IP and clinical quality controlled centrally.
              </p>
            </div>
          </ScrollReveal>
          
          <ScrollReveal delay={400}>
            <div class="text-center">
              <div class="bg-jade-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-jade-500">2</span>
              </div>
              <h3 class="font-semibold mb-2">Secure Transfer</h3>
              <p class="text-gray-600 text-base">
                Encrypted digital files sent to nearest production node.
              </p>
            </div>
          </ScrollReveal>

          <ScrollReveal delay={600}>
            <div class="text-center">
              <div class="bg-jade-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
                <span class="text-2xl font-bold text-jade-500">3</span>
              </div>
              <h3 class="font-semibold mb-2">Local Production</h3>
              <p class="text-gray-600 text-base">
                3D printing and post-processing completed locally. Fast delivery, low environmental impact.
              </p>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <section>
        <NetworkMap />
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-8 text-center">Current Production Nodes</h2>
        </ScrollReveal>

        <div class="grid md:grid-cols-3 gap-8">
          
          <!-- London -->
          <ScrollReveal delay={200}>
            <div class="border border-gray-200 rounded-lg overflow-hidden">
              <div class="h-48 overflow-hidden">
                <img 
                  src="/images/centro_lnd.jpeg" 
                  alt="London production facility" 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold mb-2">London, United Kingdom</h3>
                <p class="text-base text-gray-500 mb-4">43-45 Foley Street, London, W1W 7TY</p>
                <p class="text-gray-600 text-base mb-4">
                  Primary European hub. Serves UK hospitals and training centres. 
                  Established partnerships with NHS trusts.
                </p>
                <p class="text-sm text-gray-500">
                  Capabilities: Neurosurgical models, spine models, cranial reconstruction
                </p>
              </div>
            </div>
          </ScrollReveal>

          <!-- Zurich -->
          <ScrollReveal delay={400}>
            <div class="border border-gray-200 rounded-lg overflow-hidden">
              <div class="h-48 overflow-hidden">
                <img 
                  src="/images/zurich_lab.jpeg" 
                  alt="Zurich production facility" 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold mb-2">Zurich, Switzerland</h3>
                <p class="text-base text-gray-500 mb-4">Rieterstrasse 52, 8002 Zürich</p>
                <p class="text-gray-600 text-base mb-4">
                  Swiss precision manufacturing. Serves Central Europe. 
                  Access to advanced materials and quality control.
                </p>
                <p class="text-sm text-gray-500">
                  Capabilities: High-precision cranial models, vascular structures
                </p>
              </div>
            </div>
          </ScrollReveal>

          <!-- Taiwan -->
          <ScrollReveal delay={600}>
            <div class="border border-gray-200 rounded-lg overflow-hidden">
              <div class="h-48 overflow-hidden">
                <img 
                  src="/images/taiwan_lab.jpeg" 
                  alt="Taiwan production facility" 
                  class="w-full h-full object-cover"
                />
              </div>
              <div class="p-6">
                <h3 class="text-xl font-semibold mb-2">Taipei, Taiwan</h3>
                <p class="text-base text-gray-500 mb-4">No. 161, Section 6, Minquan E Rd, Neihu District, Taipei 114</p>
                <p class="text-gray-600 text-base mb-4">
                  Asia-Pacific hub. Fast turnaround for regional hospitals. 
                  Expanding access in underserved markets.
                </p>
                <p class="text-sm text-gray-500">
                  Capabilities: Full model range, rapid prototyping
                </p>
              </div>
            </div>
          </ScrollReveal>

        </div>
      </section>

      <section class="mt-16 bg-gray-50 rounded-lg p-8 text-center">
        <ScrollReveal>
          <h2 class="text-2xl font-semibold mb-4">Expanding Globally</h2>
          <p class="text-gray-600 max-w-2xl mx-auto">
            We are actively seeking partners to establish nodes in Europe, North America, and Asia. Our goal is to create a truly global network that can serve hospitals worldwide with fast, high-quality models. If you are interested in becoming a production partner, please <a href="/contact" class="text-jade-500 hover:underline">contact us</a>.
          </p>
        </ScrollReveal>
      </section>
    </main>
    <Footer />
  </body>
</html>